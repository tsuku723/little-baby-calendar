{
  "expo": {
    "name": "リトルベビーログ",
    "slug": "little-baby-log",
    "version": "1.1.0",
    "homepage": "https://tsuku723.github.io/little-baby-log/",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#D6EFE6"
    },
    "ios": {
      "bundleIdentifier": "studio.teeda.littlebabylog",
      "supportsTablet": false,
      "infoPlist": {
        "CFBundleDevelopmentRegion": "ja_JP",
        "CFBundleLocalizations": ["ja"],
        "NSPhotoLibraryUsageDescription": "成長記録に写真を添付するために使用します。",
        "NSUserTrackingUsageDescription": "広告の関連性を高めるために使用します。お名前や写真などの個人情報にはアクセスしません。許可しない場合も広告は表示されますが、興味に合わない広告が出やすくなります。",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["com.google.android.gms.permission.AD_ID"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-image-picker",
      "expo-tracking-transparency",
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-8166243489339783~6964568056"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "314cca80-4300-4559-8259-49453a1824a6"
      }
    }
  }
}
