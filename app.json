{
  "expo": {
    "name": "リトルベビーログ",
    "slug": "little-baby-log",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#D6EFE6"
    },
    "ios": {
      "bundleIdentifier": "studio.teeda.littlebabylog",
      "supportsTablet": false,
      "infoPlist": {
        "CFBundleDevelopmentRegion": "ja_JP",
        "CFBundleLocalizations": [
          "ja"
        ],
        "NSPhotoLibraryUsageDescription": "成長記録に写真を添付するために使用します。",
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserTrackingUsageDescription": "広告をパーソナライズするために、端末の広告識別子へのアクセス許可をお願いします。許可しない場合も広告は表示されますが、パーソナライズされない広告となります。"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-image-picker",
      "expo-tracking-transparency",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "314cca80-4300-4559-8259-49453a1824a6"
      }
    }
  }
}
